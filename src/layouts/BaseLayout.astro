---
import { getCollection } from "astro:content";
import SEO from "../components/SEO.astro";
import ThemeToggle from "../components/ThemeToggle.astro";
import { SITE_NAME, SITE_LANG, FACEBOOK_URL, PLAUSIBLE_DOMAIN, GA4_ID } from "../consts";
import { categoryUrl } from "../utils";
import "@fontsource/be-vietnam-pro/400.css";
import "@fontsource/be-vietnam-pro/600.css";
import "@fontsource/be-vietnam-pro/800.css";
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
  image?: string;
  type?: "website" | "article";
  publishDate?: Date;
  modifiedDate?: Date;
  author?: string;
  tags?: string[];
  breadcrumbs?: { name: string; url?: string }[];
  video?: { id: string; title?: string; description?: string; uploadDate?: string };
  news?: boolean;
  authorUrl?: string;
  /** Hiện thanh tiến độ đọc (cho trang bài viết) */
  showProgress?: boolean;
}

const { showProgress = false, ...seoProps } = Astro.props;
const year = new Date().getFullYear();

// Danh sách chuyên mục cho thanh điều hướng + footer
const allPosts = await getCollection("posts", ({ data }) => !data.draft);
const categories = [...new Set(allPosts.map((p) => p.data.category))].sort();
---

<!doctype html>
<html lang={SITE_LANG}>
  <head>
    <SEO {...seoProps} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link rel="alternate" type="application/rss+xml" title={SITE_NAME} href="/rss.xml" />
    <link rel="alternate" type="application/rss+xml" title={`${SITE_NAME} — Podcast`} href="/podcast.xml" />

    {/* Analytics (chỉ nhúng khi đã cấu hình trong consts.ts) */}
    {PLAUSIBLE_DOMAIN && (
      <script defer data-domain={PLAUSIBLE_DOMAIN} src="https://plausible.io/js/script.js"></script>
    )}
    {GA4_ID && (
      <>
        <script async src={`https://www.googletagmanager.com/gtag/js?id=${GA4_ID}`}></script>
        <script is:inline set:html={`window.dataLayer=window.dataLayer||[];function gtag(){dataLayer.push(arguments);}gtag('js',new Date());gtag('config','${GA4_ID}');`}></script>
      </>
    )}
    {/* Đặt theme trước khi render để tránh nhấp nháy (FOUC) */}
    <script is:inline>
      (() => {
        try {
          const t = localStorage.getItem("theme");
          const dark =
            t === "dark" ||
            (!t && matchMedia("(prefers-color-scheme: dark)").matches);
          document.documentElement.dataset.theme = dark ? "dark" : "light";
        } catch (e) {
          document.documentElement.dataset.theme = "light";
        }
      })();
    </script>
  </head>
  <body>
    {showProgress && <div class="progress-bar" id="progress"></div>}

    <header class="site-header">
      <div class="container header-inner">
        <a href="/" class="brand" aria-label={SITE_NAME}>
          <img src="/logo.png" alt={SITE_NAME} width="40" height="40" />
          <span class="visually-hidden">{SITE_NAME}</span>
        </a>

        <nav class="nav" aria-label="Categories">
          <a href="/">Home</a>
          <a href="/videos">Videos</a>
          {categories.map((cat) => <a href={categoryUrl(cat)}>{cat}</a>)}
        </nav>

        <div class="header-actions">
          <a class="icon-btn" href="/tim-kiem" aria-label="Search" title="Search">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <circle cx="11" cy="11" r="7"></circle>
              <path d="m21 21-4.3-4.3"></path>
            </svg>
          </a>
          <ThemeToggle />
        </div>
      </div>
    </header>

    <main class="container">
      <slot />
    </main>

    <footer class="site-footer">
      <div class="container">
        <div class="footer-grid">
          <div>
            <div class="footer-brand">
              <img src="/logo.png" alt={SITE_NAME} width="36" height="36" style="border-radius:8px" />
              <strong style="color:var(--text)">{SITE_NAME}</strong>
            </div>
            <p style="margin:0">Mind-blowing facts &amp; unsolved mysteries — a new one every day, in under a minute.</p>
          </div>
          <div>
            <h3>Categories</h3>
            <ul>
              {categories.map((cat) => <li><a href={categoryUrl(cat)}>{cat}</a></li>)}
            </ul>
          </div>
          <div>
            <h3>Links</h3>
            <ul>
              <li><a href="/">Home</a></li>
              <li><a href="/videos">Videos</a></li>
              <li><a href="/tim-kiem">Search</a></li>
              <li><a href="/rss.xml">RSS</a></li>
              <li><a href={FACEBOOK_URL} target="_blank" rel="noopener">Facebook</a></li>
            </ul>
          </div>
        </div>
        <div class="footer-bottom">
          <p style="margin:0">© {year} {SITE_NAME}. All rights reserved.</p>
        </div>
      </div>
    </footer>

    <button class="icon-btn scroll-top" id="scrollTop" type="button" aria-label="Back to top" title="Back to top">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="m18 15-6-6-6 6"></path>
      </svg>
    </button>

    <script is:inline>
      // Nút lên đầu trang + thanh tiến độ đọc
      (() => {
        const btn = document.getElementById("scrollTop");
        const bar = document.getElementById("progress");
        const onScroll = () => {
          const y = window.scrollY;
          if (btn) btn.classList.toggle("show", y > 500);
          if (bar) {
            const h = document.documentElement.scrollHeight - window.innerHeight;
            bar.style.width = (h > 0 ? (y / h) * 100 : 0) + "%";
          }
        };
        btn?.addEventListener("click", () =>
          window.scrollTo({ top: 0, behavior: "smooth" })
        );
        window.addEventListener("scroll", onScroll, { passive: true });
        onScroll();
      })();
    </script>
  </body>
</html>
