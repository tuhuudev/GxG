---
import { formatDate, isoDate, ogImageFor, postUrl, categoryUrl } from "../utils";

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  category: string;
  ogImage?: string;
  readingTime: string;
}
const { title, description, pubDate, category, ogImage, readingTime } =
  Astro.props;
const url = postUrl(title);
const image = ogImageFor(title, ogImage);
---

<article class="featured">
  <a href={url} class="media" aria-label={title}>
    <img src={image} alt={title} width="1200" height="630" fetchpriority="high" decoding="async" />
  </a>
  <div class="body">
    <div class="meta">
      <a class="badge" href={categoryUrl(category)}>{category}</a>
      <time datetime={isoDate(pubDate)}>{formatDate(pubDate)}</time>
      <span class="dot">{readingTime}</span>
    </div>
    <h2><a href={url}>{title}</a></h2>
    <p>{description}</p>
    <a href={url} style="font-weight:700">Đọc tiếp →</a>
  </div>
</article>
