---
import BaseLayout from "../layouts/BaseLayout.astro";
import { SITE_NAME } from "../consts";
---

<BaseLayout
  title="Search"
  description={`Search posts on ${SITE_NAME}`}
  type="website"
>
  <section class="page-intro">
    <h1>Search</h1>
    <p>Type a keyword to search posts.</p>
  </section>

  <div class="search-wrap">
    <div id="search"></div>
    <noscript>Please enable JavaScript to use search.</noscript>
  </div>

  <link rel="stylesheet" href="/pagefind/pagefind-ui.css" />
  <script src="/pagefind/pagefind-ui.js" is:inline></script>
  <script is:inline>
    window.addEventListener("DOMContentLoaded", () => {
      if (typeof window.PagefindUI === "undefined") {
        document.getElementById("search").innerHTML =
          '<p style="color:var(--muted)">Search only works on the production build (run <code>npm run build</code> then <code>npm run preview</code>), not in dev mode.</p>';
        return;
      }
      new window.PagefindUI({
        element: "#search",
        showSubResults: true,
        showImages: false,
        translations: {
          placeholder: "Search posts...",
          zero_results: "No results for [SEARCH_TERM]",
          many_results: "[COUNT] results for [SEARCH_TERM]",
          one_result: "[COUNT] result for [SEARCH_TERM]",
          clear_search: "Clear",
          load_more: "Load more results",
          search_label: "Search",
        },
      });

      // Hỗ trợ ?q=... (cho JSON-LD SearchAction / sitelinks searchbox của Google):
      // điền sẵn từ khóa vào ô tìm để Pagefind chạy ngay.
      const q = new URLSearchParams(location.search).get("q");
      if (q) {
        const input = document.querySelector(".pagefind-ui__search-input");
        if (input) {
          input.value = q;
          input.dispatchEvent(new Event("input", { bubbles: true }));
        }
      }
    });
  </script>
</BaseLayout>
