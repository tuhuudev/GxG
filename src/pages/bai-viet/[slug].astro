---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import TableOfContents from "../../components/TableOfContents.astro";
import ShareButtons from "../../components/ShareButtons.astro";
import RelatedPosts from "../../components/RelatedPosts.astro";
import Comments from "../../components/Comments.astro";
import {
  formatDate,
  isoDate,
  slugify,
  ogImageFor,
  postUrl,
  categoryUrl,
  categoryGradientCss,
  readingTime,
} from "../../utils";
import { DEFAULT_AUTHOR, SITE_URL, SITE_NAME } from "../../consts";
import fs from "node:fs";
import path from "node:path";

export async function getStaticPaths() {
  const posts = await getCollection("posts", ({ data }) => !data.draft);

  return posts.map((post) => {
    const related = posts
      .filter((p) => p.id !== post.id)
      .map((p) => {
        let score = 0;
        if (p.data.category === post.data.category) score += 3;
        score += p.data.tags.filter((t) => post.data.tags.includes(t)).length;
        return { p, score };
      })
      .filter((x) => x.score > 0)
      .sort(
        (a, b) =>
          b.score - a.score ||
          b.p.data.pubDate.valueOf() - a.p.data.pubDate.valueOf()
      )
      .slice(0, 3)
      .map((x) => x.p);

    return {
      params: { slug: slugify(post.data.title) },
      props: { post, related },
    };
  });
}

const { post, related } = Astro.props;
const { data } = post;
const { Content, headings } = await render(post);
const author = data.author ?? DEFAULT_AUTHOR;
const absoluteUrl = new URL(Astro.url.pathname, SITE_URL).href;
const ogImage = ogImageFor(data.title, data.ogImage);
const time = readingTime(post.body ?? "");
const initial = author.charAt(0).toUpperCase();
const catGradient = categoryGradientCss(data.category);

// Nếu bài nhúng video YouTube -> khai báo VideoObject (video rich result).
const videoId = (post.body ?? "").match(/youtube\.com\/embed\/([\w-]{11})/)?.[1];
const video = videoId
  ? {
      id: videoId,
      title: data.title,
      description: data.description,
      uploadDate: data.pubDate.toISOString(),
    }
  : undefined;

// Breadcrumb cho JSON-LD BreadcrumbList (khớp với <Breadcrumbs> hiển thị).
const crumbs = [
  { name: "Home", url: "/" },
  { name: data.category, url: categoryUrl(data.category) },
  { name: data.title },
];

// Bản đọc audio (do dự án video sinh bằng edge-tts) -> nút "Nghe bài viết".
const audioSrc = `/audio/${slugify(data.title)}.mp3`;
const hasAudio = fs.existsSync(path.join(process.cwd(), "public", "audio", `${slugify(data.title)}.mp3`));
---

<BaseLayout
  title={data.title}
  description={data.description}
  image={ogImage}
  type="article"
  publishDate={data.pubDate}
  modifiedDate={data.updatedDate}
  author={author}
  tags={data.tags}
  breadcrumbs={crumbs}
  video={video}
  news={data.news}
  showProgress
>
  <article class="article" data-pagefind-body>
    <Breadcrumbs
      items={[
        { label: "Home", href: "/" },
        { label: data.category, href: categoryUrl(data.category) },
        { label: data.title },
      ]}
    />

    <header class="article-header">
      <a class="badge" href={categoryUrl(data.category)} style={`background:${catGradient}`}>{data.category}</a>
      <h1>{data.title}</h1>
      <p class="article-lead">{data.description}</p>

      <div class="byline">
        <span class="avatar" aria-hidden="true" style={`background:${catGradient}`}>{initial}</span>
        <span class="info">
          <span class="name">{author}</span>
          <span class="meta">
            <time datetime={isoDate(data.pubDate)}>{formatDate(data.pubDate)}</time>
            {
              data.updatedDate && (
                <span class="dot">
                  Updated <time datetime={isoDate(data.updatedDate)}>{formatDate(data.updatedDate)}</time>
                </span>
              )
            }
            <span class="dot">{time}</span>
          </span>
        </span>
      </div>

      {
        data.ogImage && (
          <img
            class="article-cover"
            src={data.ogImage}
            alt={data.title}
            width="1200"
            height="630"
            fetchpriority="high"
            decoding="async"
          />
        )
      }
    </header>

    <div class="article-layout">
      <TableOfContents headings={headings} />

      <div class="article-main">
        {
          data.takeaways.length > 0 && (
            <aside class="takeaways" aria-label="Key takeaways">
              <p class="takeaways-title">⚡ Key takeaways</p>
              <ul>
                {data.takeaways.map((t) => (
                  <li>{t}</li>
                ))}
              </ul>
            </aside>
          )
        }

        {
          hasAudio && (
            <div class="audio-player">
              <span class="audio-label">🎧 Listen</span>
              <audio controls preload="none" src={audioSrc}></audio>
            </div>
          )
        }

        <div class="prose">
          <Content />
        </div>

        {
          data.tags.length > 0 && (
            <ul class="tags">
              {data.tags.map((tag) => (
                <li><span class="tag">#{tag}</span></li>
              ))}
            </ul>
          )
        }

        <ShareButtons url={absoluteUrl} title={data.title} />
        <a class="back-link" href="/">← Back to home</a>
      </div>
    </div>

    <RelatedPosts posts={related} />
    <Comments />
  </article>
</BaseLayout>

<style>
  .takeaways {
    margin: 0 0 1.5rem;
    padding: 1.1rem 1.25rem;
    border: 1px solid var(--border, #e5e7eb);
    border-left: 4px solid var(--accent, #3b82f6);
    border-radius: 12px;
    background: var(--surface, rgba(59, 130, 246, 0.06));
  }
  .takeaways-title {
    margin: 0 0 0.5rem;
    font-weight: 700;
    font-size: 0.95rem;
    text-transform: uppercase;
    letter-spacing: 0.03em;
  }
  .takeaways ul { margin: 0; padding-left: 1.2rem; }
  .takeaways li { margin: 0.3rem 0; line-height: 1.5; }

  .audio-player {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
    padding: 0.75rem 1rem;
    margin: 0 0 1.5rem;
    border: 1px solid var(--border, #e5e7eb);
    border-radius: 12px;
    background: var(--surface, rgba(0, 0, 0, 0.03));
  }
  .audio-player .audio-label { font-weight: 600; white-space: nowrap; }
  .audio-player audio { flex: 1; min-width: 220px; height: 36px; }
</style>
