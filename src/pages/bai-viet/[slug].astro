---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import ShareButtons from "../../components/ShareButtons.astro";
import RelatedPosts from "../../components/RelatedPosts.astro";
import { formatDate, isoDate, slugify, ogImageFor } from "../../utils";
import { DEFAULT_AUTHOR, SITE_URL } from "../../consts";

// Sinh trang tĩnh cho từng bài viết. Slug lấy từ tiêu đề (bỏ dấu).
export async function getStaticPaths() {
  const posts = await getCollection("posts", ({ data }) => !data.draft);

  return posts.map((post) => {
    // Tính bài liên quan: ưu tiên cùng chuyên mục, sau đó là trùng tag.
    const related = posts
      .filter((p) => p.id !== post.id)
      .map((p) => {
        let score = 0;
        if (p.data.category === post.data.category) score += 3;
        score += p.data.tags.filter((t) => post.data.tags.includes(t)).length;
        return { p, score };
      })
      .filter((x) => x.score > 0)
      .sort(
        (a, b) =>
          b.score - a.score ||
          b.p.data.pubDate.valueOf() - a.p.data.pubDate.valueOf()
      )
      .slice(0, 3)
      .map((x) => x.p);

    return {
      params: { slug: slugify(post.data.title) },
      props: { post, related },
    };
  });
}

const { post, related } = Astro.props;
const { data } = post;
const { Content } = await render(post);
const author = data.author ?? DEFAULT_AUTHOR;
const absoluteUrl = new URL(Astro.url.pathname, SITE_URL).href;
// Ảnh cho thẻ og:image: ảnh thật nếu có, ngược lại dùng ảnh tự sinh
const ogImage = ogImageFor(data.title, data.ogImage);
---

<BaseLayout
  title={data.title}
  description={data.description}
  image={ogImage}
  type="article"
  publishDate={data.pubDate}
  modifiedDate={data.updatedDate}
  author={author}
  tags={data.tags}
>
  <article class="article">
    <header class="article-header">
      <div class="meta">
        <a class="badge" href={`/danh-muc/${slugify(data.category)}`}>{data.category}</a>
        <time datetime={isoDate(data.pubDate)}>{formatDate(data.pubDate)}</time>
        <span>·</span>
        <span>{author}</span>
      </div>
      <h1>{data.title}</h1>
      <p style="color:var(--color-muted);font-size:1.1rem">{data.description}</p>
    </header>

    {
      data.ogImage && (
        <img
          class="article-cover"
          src={data.ogImage}
          alt={data.title}
          width="1200"
          height="630"
          fetchpriority="high"
          decoding="async"
        />
      )
    }

    <div class="prose">
      <Content />
    </div>

    <ShareButtons url={absoluteUrl} title={data.title} />

    <a class="back-link" href="/">← Về trang chủ</a>

    <RelatedPosts posts={related} />
  </article>
</BaseLayout>
