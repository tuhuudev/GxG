---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import TableOfContents from "../../components/TableOfContents.astro";
import ShareButtons from "../../components/ShareButtons.astro";
import RelatedPosts from "../../components/RelatedPosts.astro";
import {
  formatDate,
  isoDate,
  slugify,
  ogImageFor,
  postUrl,
  categoryUrl,
  readingTime,
} from "../../utils";
import { DEFAULT_AUTHOR, SITE_URL, SITE_NAME } from "../../consts";

export async function getStaticPaths() {
  const posts = await getCollection("posts", ({ data }) => !data.draft);

  return posts.map((post) => {
    const related = posts
      .filter((p) => p.id !== post.id)
      .map((p) => {
        let score = 0;
        if (p.data.category === post.data.category) score += 3;
        score += p.data.tags.filter((t) => post.data.tags.includes(t)).length;
        return { p, score };
      })
      .filter((x) => x.score > 0)
      .sort(
        (a, b) =>
          b.score - a.score ||
          b.p.data.pubDate.valueOf() - a.p.data.pubDate.valueOf()
      )
      .slice(0, 3)
      .map((x) => x.p);

    return {
      params: { slug: slugify(post.data.title) },
      props: { post, related },
    };
  });
}

const { post, related } = Astro.props;
const { data } = post;
const { Content, headings } = await render(post);
const author = data.author ?? DEFAULT_AUTHOR;
const absoluteUrl = new URL(Astro.url.pathname, SITE_URL).href;
const ogImage = ogImageFor(data.title, data.ogImage);
const time = readingTime(post.body ?? "");
const initial = author.charAt(0).toUpperCase();
---

<BaseLayout
  title={data.title}
  description={data.description}
  image={ogImage}
  type="article"
  publishDate={data.pubDate}
  modifiedDate={data.updatedDate}
  author={author}
  tags={data.tags}
  showProgress
>
  <Breadcrumbs
    items={[
      { label: "Trang chủ", href: "/" },
      { label: data.category, href: categoryUrl(data.category) },
      { label: data.title },
    ]}
  />

  <article class="article" data-pagefind-body>
    <header class="article-header">
      <a class="badge" href={categoryUrl(data.category)}>{data.category}</a>
      <h1>{data.title}</h1>
      <p class="article-lead">{data.description}</p>

      <div class="byline">
        <span class="avatar" aria-hidden="true">{initial}</span>
        <span class="info">
          <span class="name">{author}</span>
          <span class="meta">
            <time datetime={isoDate(data.pubDate)}>{formatDate(data.pubDate)}</time>
            <span class="dot">{time}</span>
          </span>
        </span>
      </div>

      {
        data.ogImage && (
          <img
            class="article-cover"
            src={data.ogImage}
            alt={data.title}
            width="1200"
            height="630"
            fetchpriority="high"
            decoding="async"
          />
        )
      }
    </header>

    <div class="article-layout">
      <TableOfContents headings={headings} />

      <div class="article-main">
        <div class="prose">
          <Content />
        </div>

        {
          data.tags.length > 0 && (
            <ul class="tags">
              {data.tags.map((tag) => (
                <li><span class="tag">#{tag}</span></li>
              ))}
            </ul>
          )
        }

        <ShareButtons url={absoluteUrl} title={data.title} />
        <a class="back-link" href="/">← Về trang chủ</a>
      </div>
    </div>

    <RelatedPosts posts={related} />
  </article>
</BaseLayout>
