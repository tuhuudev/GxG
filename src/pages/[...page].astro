---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import FeaturedPost from "../components/FeaturedPost.astro";
import PostCard from "../components/PostCard.astro";
import { SITE_NAME, SITE_DESCRIPTION } from "../consts";
import { readingTime } from "../utils";

export async function getStaticPaths({ paginate }) {
  const PAGE_SIZE = 7; // 1 bài nổi bật + 6 bài lưới ở trang đầu
  const posts = (await getCollection("posts", ({ data }) => !data.draft)).sort(
    (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
  );
  return paginate(posts, { pageSize: PAGE_SIZE });
}

const { page } = Astro.props;
const isFirstPage = page.currentPage === 1;
const pageTitle = isFirstPage
  ? SITE_NAME
  : `${SITE_NAME} — Trang ${page.currentPage}`;

// Trang đầu: bài mới nhất làm nổi bật, còn lại vào lưới
const featured = isFirstPage ? page.data[0] : null;
const gridPosts = isFirstPage ? page.data.slice(1) : page.data;
---

<BaseLayout title={pageTitle} description={SITE_DESCRIPTION} type="website">
  {
    isFirstPage && (
      <section class="page-intro">
        <h1>{SITE_NAME}</h1>
        <p>{SITE_DESCRIPTION}</p>
      </section>
    )
  }

  {
    featured && (
      <FeaturedPost
        title={featured.data.title}
        description={featured.data.description}
        pubDate={featured.data.pubDate}
        category={featured.data.category}
        ogImage={featured.data.ogImage}
        readingTime={readingTime(featured.body ?? "")}
      />
    )
  }

  {gridPosts.length > 0 && <h2 class="section-title">Bài viết mới nhất</h2>}

  <ul class="post-grid">
    {
      gridPosts.map((post) => (
        <PostCard
          title={post.data.title}
          description={post.data.description}
          pubDate={post.data.pubDate}
          category={post.data.category}
          ogImage={post.data.ogImage}
          readingTime={readingTime(post.body ?? "")}
        />
      ))
    }
  </ul>

  {
    page.lastPage > 1 && (
      <nav class="pagination" aria-label="Phân trang">
        {page.url.prev ? <a href={page.url.prev}>← Trước</a> : <span class="disabled">← Trước</span>}
        <span class="page-info">Trang {page.currentPage} / {page.lastPage}</span>
        {page.url.next ? <a href={page.url.next}>Sau →</a> : <span class="disabled">Sau →</span>}
      </nav>
    )
  }

  {
    page.data.length === 0 && (
      <p>Chưa có bài viết nào. Thêm file .md vào <code>src/content/posts/</code>.</p>
    )
  }
</BaseLayout>
